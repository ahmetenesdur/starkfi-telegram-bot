# Required
TELEGRAM_BOT_TOKEN=
BOT_ENCRYPTION_SECRET=              # 64-char hex: openssl rand -hex 32
STARKFI_SERVER_URL=

# Optional
# STARKFI_MCP_COMMAND=npx
# STARKFI_MCP_ARGS=-y,starkfi@latest,mcp-start
# LOG_LEVEL=info
# MAX_HISTORY=20
# RATE_LIMIT_PER_MINUTE=30
# MCP_IDLE_TIMEOUT_MS=300000
# PORT=8080

# Webhook mode (omit for long-polling)
# WEBHOOK_DOMAIN=https://bot.example.com
# WEBHOOK_SECRET_PATH=/webhook/secret-path

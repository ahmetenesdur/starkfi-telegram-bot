# Required
TELEGRAM_BOT_TOKEN=
BOT_ENCRYPTION_SECRET=
STARKFI_SERVER_URL=

# Webhook (set for production, leave empty for local polling)
# WEBHOOK_URL=https://xxxxx.awsapprunner.com
# WEBHOOK_SECRET=<run: openssl rand -hex 32>

# Optional
# STARKFI_MCP_COMMAND=npx
# STARKFI_MCP_ARGS=-y,starkfi@latest,mcp-start
# LOG_LEVEL=info
# MAX_HISTORY=20
# RATE_LIMIT_PER_MINUTE=30
# MCP_IDLE_TIMEOUT_MS=300000

{
  "name": "starkfi-telegram-bot",
  "version": "0.1.0",
  "description": "AI-powered Telegram bot for StarkFi DeFi on Starknet — bring your own model (OpenAI, Claude, Gemini)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsup",
    "start": "node --env-file=.env dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "keywords": [
    "starknet",
    "defi",
    "telegram",
    "bot",
    "starkfi",
    "mcp",
    "ai",
    "openai",
    "claude",
    "gemini"
  ],
  "author": "ahmetenesdur",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.0",
    "@ai-sdk/google": "^3.0.0",
    "@ai-sdk/mcp": "latest",
    "@ai-sdk/openai": "^3.0.0",
    "ai": "^6.0.0",
    "better-sqlite3": "^12.0.0",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.57.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  }
}
